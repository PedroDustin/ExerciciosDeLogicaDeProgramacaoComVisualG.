Algoritmo "PAGINA25-L"
// Disciplina   : [Lógica de Programaçăo VisualG]
// Professor    : Jailson Santos
// Descriçăo    : Ler tręs valores (A, B e C) e calcular a soma dos quadrados
// desses valores.
// Autor(a)     : Pedro Henrique
// Data atual   : 22/04/2026

Var
// Seçăo de Declaraçőes das variáveis
   A, B, C: real
   somaQuadrados: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...

   Escreval("Digite o valor de A: ")
   leia(A)
   Escreval("Digite o valor de B: ")
   leia(B)
   Escreval("Digite o valor de C: ")
   leia(C)
   somaQuadrados <- (A ^ 2) + (B ^ 2) + (C ^ 2)

   Escreval("A soma dos quadrados é: ", somaQuadrados)

Fimalgoritmo