Algoritmo "PAGINA25-G"
// Disciplina: [Lógica de Programaçăo com visualG]
// Professor: Jailson Santos
// Descriçăo: Somar e multiplicar os valores entre si
// Autor(a): Pedro Henrique
// Data atual: 19/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   a, b, c, d: inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   Escreval("Digite o valor de A: ")
   leia(a)
   Escreval("Digite o valor de B: ")
   leia(b)
   Escreval("Digite o valor de C: ")
   leia(c)
   Escreval("Digite o valor de D: ")
   leia(d)
   Escreval("A + B = ", a + b)
   Escreval("A * B = ", a * b)

   Escreval("A + C = ", a + c)
   Escreval("A * C = ", a * c)

   Escreval("A + D = ", a + d)
   Escreval("A * D = ", a * d)

   Escreval("B + C = ", b + c)
   Escreval("B * C = ", b * c)

   Escreval("B + D = ", b + d)
   Escreval("B * D = ", b * d)

   Escreval("C + D = ", c + d)
   Escreval("C * D = ", c * d)

Fimalgoritmo