Algoritmo "exercicio16"
// Disciplina   : [Lógica de Programaçăo VisualG]
// Professor    : Jailson Santos
// Descriçăo    : Leia o salário atual de um funcionário e o percentual
// de aumento. Calcule o novo salário.
// Autor(a)     : Pedro Henrique
// Data atual   : 22/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   salario, aumento, novoSalario: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...

   Escreval("Digite o valor do seu salário: ")
   Leia(salario)

   Escreval("Digite o percentual de aumento: ")
   Leia(aumento)

   novoSalario <- salario + (salario * aumento / 100)

   Escreval("Seu novo salário é: ", novoSalario)

Fimalgoritmo