Algoritmo "exercicio22"
// Disciplina   : [Lógica de Programaçăo VisualG]
// Professor    : Jailson Santos
// Descriçăo    : Leia dois valores armazenados nas variáveis A e B.
// Troque os valores entre elas.
// Autor(a)     : Pedro Henrique
// Data atual   : 22/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   A, B, auxiliar: inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...

   A <- 10
   B <- 20

   auxiliar <- A
   A <- B
   B <- auxiliar

   Escreval("O valor de A é: ", A)
   Escreval("O valor de B é: ", B)

Fimalgoritmo