Algoritmo "Exercicio11"
// Disciplina   : [Lógica de Programaçăo VisualG]
// Professor   : jailson Santos
// Descriçăo   : Escreva um algoritmo para ler uma temperatura em graus
// Fahrenheit, calcular e escrever o valor correspondente em graus Celsius
// Autor(a)    : Pedro Henrique
// Data atual  : 06/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   celsius, fahrenheit: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   Escreval ("Digite a temperatura em Fahrenheit")
   leia(Fahrenheit)
   celsius <- (Fahrenheit - 32) / 9 * 5
   Escreval ("A temperatura em graus Celsius é :", celsius)
Fimalgoritmo