Algoritmo "Identificar Poligono"
// Disciplina: [Lógica de Programaçăo com visualG]
// Professor: Jailson
// Descriçăo: Identificar tipo de poligono pelo numero de lados
// Autor(a): Luana
// Data atual: 16/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
    lados, medida, perimetro, area: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
    escreval("Digite o numero de lados: ")
   leia(lados)
   se (lados < 3) entao
      escreval("NAO E UM POLIGONO")
   senao
      se (lados > 5) entao
         escreval("POLIGONO NAO IDENTIFICADO")
      senao
         escreval("Digite a medida do lado em cm: ")
         leia(medida)
         se (lados = 3) entao
            perimetro <- medida * 3
            escreval("TRIANGULO")
            escreval("Perimetro: ", perimetro)
         senao
            se (lados = 4) entao
               area <- medida * medida
               escreval("QUADRADO")
               escreval("Area: ", area)
            senao
               escreval("PENTAGONO")
            fimse
         fimse
      fimse
   fimse


Fimalgoritmo