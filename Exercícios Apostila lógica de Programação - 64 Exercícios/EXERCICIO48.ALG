Algoritmo "exercicio48"
// Disciplina: [Lógica de Programaçăo com visualG]
// Professor: Jailson Santos
// Descriçăo: Ler o código de origem de um produto e informar a sua
//regiăo de procedęncia.
// Autor(a): Pedro Henrique
// Data atual: 16/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   nota1, nota2, optativa, media: real


Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   Escreval("Digite a primeira nota: ")
   leia(nota1)
   Escreval("Digite a segunda nota: ")
   leia(nota2)
   Escreval("Digite a nota da optativa (-1 caso nao tenha feito): ")
   leia(optativa)
   se (optativa <> -1) entao
   senăo
      se (nota1 < nota2) entao
         nota1 <- optativa
      senao
         se
         nota2 <- optativa
         media <- (nota1 + nota2) / 2
         Escreval("Media final: ", media)
         se (media >= 6) entao
            Escreval("Aprovado")
         senao
            se (media < 3) entao
               Escreval("Reprovado")
            senao
               Escreval("Exame")
            fimse
         fimse
      fimse
   fimse

Fimalgoritmo