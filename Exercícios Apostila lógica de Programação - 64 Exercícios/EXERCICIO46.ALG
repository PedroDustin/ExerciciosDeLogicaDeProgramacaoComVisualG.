Algoritmo "exercicio46"
// Disciplina: [Lógica de Programaçăo com visualG]
// Professor: Jailson Santos
// Descriçăo: Ler o código de usuário e a senha, verificar se estăo
// corretos e mostrar a mensagem correspondente.
// Autor(a): Pedro Henrique
// Data atual: 16/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   codigo, senha: inteiro


Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
Escreval("Digite o codigo")
leia(codigo)
se (codigo = 1234) entao
   Escreval("Usuario valido")
   Escreval("Digite a senha")
   leia(senha)
   se (senha = 9999) entao
      Escreval("Acesso permitido")
   senao
      Escreval("Acesso negado")
   fimse
senao
   Escreval("Usuario invalido")
fimse

Fimalgoritmo